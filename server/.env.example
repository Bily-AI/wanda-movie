# ===== 万达售票后端 生产环境变量模板 =====
# 复制成 .env 再改值:  cp .env.example .env
# 千万不要把 .env 提交到 git(已在 .gitignore 里忽略)

# SQLite 数据库文件(相对 prisma/ 目录)。prisma migrate deploy 会自动创建。
DATABASE_URL="file:./prod.db"

# JWT 签名密钥 —— 必须改成随机长串。生成方法:
#   openssl rand -hex 32
JWT_SECRET="改成openssl随机生成的64位十六进制"

# 后台密钥(百度OCR/DeepSeek)加密用的密钥 —— 也必须改。
#   openssl rand -hex 32
# 注意:一旦设过并保存过密钥,就不要再改这个值,否则已加密的密钥解不开。
CONFIG_ENC_KEY="改成另一个openssl随机生成的64位十六进制"

# 管理后台登录密码 —— 必须改,别用默认 admin888
ADMIN_PASSWORD="改成你自己的强密码"

# 监听端口。3x-ui 面板/节点不占 3000 的话保持即可。
PORT=3000

NODE_ENV=production

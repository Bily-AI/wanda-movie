{
  "name": "wanda-ticket-tool",
  "version": "1.0.0",
  "description": "万达快速出票 1.0.0 重构版",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "check:all": "node tools/check-all-contracts.mjs",
    "check:all-contracts": "node tools/check-all-contracts-contract.mjs",
    "check:renderer": "node tools/check-renderer-contract.mjs",
    "check:phase2": "node tools/check-phase2-contract.mjs",
    "check:phase3": "node tools/check-phase3-contract.mjs",
    "check:phase4": "node tools/check-phase4-contract.mjs",
    "check:flow": "node tools/check-flow-contract.mjs",
    "check:ocr": "node --experimental-strip-types tools/check-ocr-contract.mjs",
    "check:ai-ocr": "node tools/check-ai-ocr-contract.mjs",
    "check:ticket-code": "node tools/check-ticket-code-contract.mjs",
    "check:history-ticket-code": "node tools/check-history-ticket-code-contract.mjs",
    "check:history-order-layout": "node tools/check-history-order-layout-contract.mjs",
    "check:payment-submit": "node tools/check-payment-submit-contract.mjs",
    "check:wanda-diagnostics": "node tools/check-wanda-diagnostics-contract.mjs",
    "check:activity-gift": "node tools/check-activity-gift-contract.mjs",
    "check:activity-layout": "node tools/check-activity-layout-contract.mjs",
    "check:coupon-present": "node tools/check-coupon-present-contract.mjs",
    "check:coupon-category": "node tools/check-coupon-category-contract.mjs",
    "check:coupon-layout": "node tools/check-coupon-layout-contract.mjs",
    "check:proxy-bridge": "node tools/check-proxy-bridge-contract.mjs",
    "check:auto-order": "node tools/check-auto-order-contract.mjs",
    "check:auto-order-layout": "node tools/check-auto-order-layout-contract.mjs",
    "check:alipay-bridge": "node tools/check-alipay-bridge-contract.mjs",
    "check:alipay-ui": "node tools/check-alipay-ui-contract.mjs",
    "check:stored-card": "node tools/check-stored-card-contract.mjs",
    "check:stored-card-layout": "node tools/check-stored-card-layout-contract.mjs",
    "check:member-signin": "node tools/check-member-signin-contract.mjs",
    "check:member-module": "node tools/check-member-module-contract.mjs",
    "check:member-layout": "node tools/check-member-layout-contract.mjs",
    "check:global-account-sidebar": "node tools/check-global-account-sidebar-contract.mjs",
    "check:ui-workbench-layout": "node tools/check-ui-workbench-layout-contract.mjs",
    "check:log-layout": "node tools/check-log-layout-contract.mjs",
    "check:settings-layout": "node tools/check-settings-layout-contract.mjs",
    "check:interface-smoke": "node tools/check-interface-smoke-contract.mjs",
    "smoke:wanda": "node tools/smoke-wanda-api.mjs",
    "index:old": "node tools/old-package-index.mjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "docx": "^9.7.1",
    "element-plus": "^2.4.0",
    "jsencrypt": "^3.5.4",
    "pinia": "^2.1.0",
    "pinyin-pro": "^3.28.1",
    "qrcode": "^1.5.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.5",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0"
  }
}
